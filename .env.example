# Database
DATABASE_URL="postgresql://aura:aura@localhost:5432/aura"

# Auth (Better Auth)
BETTER_AUTH_SECRET="change-me-to-a-random-32-char-string-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# Redis
REDIS_URL="redis://localhost:6379"

# YouTube (Google Cloud Console)
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""

# AI — LOCAL FIRST (Ollama, fully offline)
# Set OLLAMA_BASE_URL to use a local model. If set, Anthropic/OpenAI are ignored.
# Run: docker compose -f docker/docker-compose.dev.yml up -d  (includes Ollama)
# Models: llama3.2 (default), mistral, codellama, qwen2.5, deepseek-r1
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"

# AI — CLOUD FALLBACK (BYOK — only used if OLLAMA_BASE_URL is not set)
# Priority: Anthropic → OpenAI → Groq (if no OLLAMA_BASE_URL)
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GROQ_API_KEY=""          # https://console.groq.com/keys — fastest inference, free tier
GOOGLE_API_KEY=""        # https://aistudio.google.com/apikey
MISTRAL_API_KEY=""       # https://console.mistral.ai/api-keys

# n8n (self-hosted instance)
N8N_URL="http://localhost:5678"
N8N_API_KEY=""

# Postiz (self-hosted instance)
NEXT_PUBLIC_POSTIZ_URL="http://localhost:3001"
POSTIZ_API_KEY=""

# Coolify (your Hetzner server)
COOLIFY_URL="https://coolify.yourdomain.com"
COOLIFY_API_KEY=""

# Vault encryption key (generate with: openssl rand -base64 32)
VAULT_ENCRYPTION_KEY=""

# Telegram (optional — for agent notifications)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
