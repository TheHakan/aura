{
  "name": "aura",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:migrate": "turbo run db:migrate --filter=@aura/web",
    "db:studio": "turbo run db:studio --filter=@aura/web",
    "db:seed": "turbo run db:seed --filter=@aura/web",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "prettier": "^3.5.3",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver",
      "@img/sharp-libvips-linuxmusl-x64",
      "@next/swc-linux-x64-gnu",
      "@next/swc-linux-x64-musl"
    ]
  }
}
